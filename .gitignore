# Git ignore for Trendify React App

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (optional - we track dist since no source)
# dist/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor directories
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# Jenkins
.jenkins/

# Docker
*.tar

# Logs
logs/
*.log
