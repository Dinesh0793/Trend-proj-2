*.tfstate*

# Kubernetes configs (kept separate)
k8s/

# Jenkins
Jenkinsfile

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test files
*.test.js
__tests__/
